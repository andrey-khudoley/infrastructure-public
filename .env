# ============================================================================
# Конфигурация infrastructure-public (bootstrap) — единственный файл настроек
# ============================================================================
#
# Секреты (пароли, токены, приватные ключи) сюда не кладём — файл коммитится.
#
# Подхватывается: start.sh → scripts/lib/load-env.sh
#
# Приоритет: переменные окружения до запуска > значения из этого файла
#
# Формат: KEY=VALUE без пробелов вокруг `=`. Комментарии — строкой с «#».
# Значения со спецсимволами оборачивайте в "…" или '…'.
#
# Соглашения: ENV_VALUE и REF_VALUE выставляются в load-env.sh из ENV и REF
# (см. шаг 70 — export в make).

# --- Приватный репозиторий и ref (шаги 50, 70) --------------------------------

ENV=ctl
REPO_URL=https://github.com/andrey-khudoley/infrastructure-private.git
REF=v26-1
PULL_DIR=/var/lib/infra/src
SKIP_ANSIBLE=0

# --- Ansible Galaxy / Makefile в приватном репо (шаг 70) -----------------------

GALAXY_INSTALL_TIMEOUT=300
GALAXY_DOWNLOAD_DIR=/var/lib/infra/galaxy-download
GALAXY_INSTALL_RETRIES=5
GALAXY_RETRY_SLEEP_SEC=10

# --- SSH deploy key (шаг 30) -------------------------------------------------

INFRA_SSH_KEY=/root/.ssh/id_ed25519_infra
INFRA_SSH_KEY_COMMENT=infra@repo
INFRA_SSH_SKIP_PROMPT=0

# --- Профиль дисков (шаг 40) -------------------------------------------------
# VAR_ALLOW_ROOT_DISK: по умолчанию 1 (см. scripts/40-disk-storage.sh); 0 — не размечать диск с корнем.
# VAR_ALLOW_ROOT_DISK_SKIP_PROMPT=1 — без паузы Enter при предупреждении (CI).

DISK_VARS_FILE=/etc/infra/bootstrap-disk.env
DISK_VARS_REPO_PATH=bootstrap-disk.env
DISK_PROFILE_FETCH_FROM_REPO=1
MAIN_DISK_DEVICE=
