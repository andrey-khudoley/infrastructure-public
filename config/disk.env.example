# ---------------------------------------------------------------------------
# Образец переопределений матрицы config/disk-profiles.sh (шаг 20, start.sh)
# ---------------------------------------------------------------------------
# По умолчанию этого файла нет в репозитории — работает только матрица.
# Чтобы задать свои числа или MAIN_DISK_DEVICE, скопируйте в клоне публичного репо:
#   cp config/disk.env.example config/disk.env
# отредактируйте config/disk.env и запустите start.sh.
#
# Файл config/disk.env в .gitignore — не коммитьте переопределения в общий репозиторий,
# если они специфичны для узла.
#
# Формат: KEY=VALUE, source через load-env.sh — только безопасные ключи разметки.

# --- Примеры (раскомментируйте и подставьте свои значения) ---

# Минимум остатка для выделения MinIO (GiB)
#MIN_MINIO_G=15

#ROOT_TARGET_G=12
#VAR_SIZE_G=15
#MINIO_SIZE_G=0
#SWAP_SIZE_G=2
#BOOT_SIZE_G=1

# Минимум свободного места под /var (MiB); часто VAR_SIZE_G * 1024
#VAR_MIN_FREE_MIB=15360

# Явный диск для /var и /minio, например /dev/vdb
#VAR_DISK_DEVICE=

# 1 — разрешить разметку на диске с корнем; 0 — не трогать root-диск
#VAR_ALLOW_ROOT_DISK=0
#VAR_ALLOW_ROOT_DISK_SKIP_PROMPT=0

# Принудительно указать основной диск для расчёта профиля
#MAIN_DISK_DEVICE=

# Отключить матрицу и оставить только значения из этого файла + apply_disk_defaults:
#DISK_PROFILE_USE_MATRIX=0
