# ---------------------------------------------------------------------------
# Профиль дисков (шаг 20; см. scripts/20-disk-storage.sh)
# ---------------------------------------------------------------------------
# Локальная копия профиля на узле (после загрузки из репо или вручную)
DISK_VARS_FILE=/etc/infra/bootstrap-disk.env

# Путь к профилю внутри приватного репозитория (KEY=VALUE, source в скрипте)
DISK_VARS_REPO_PATH=config/disk.env

DISK_PROFILE_FETCH_FROM_REPO=1

# Матрица размеров: config/disk-profiles.sh (включена по умолчанию). Отключить: DISK_PROFILE_USE_MATRIX=0
# DISK_PROFILE_USE_MATRIX=0

# MAIN_DISK_DEVICE=

# VAR_ALLOW_ROOT_DISK: 1 — разметка на диске с корнем (см. 20-disk-storage); 0 — не трогать
# VAR_ALLOW_ROOT_DISK=1
# VAR_ALLOW_ROOT_DISK_SKIP_PROMPT=0
