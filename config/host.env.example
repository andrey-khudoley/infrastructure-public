# ---------------------------------------------------------------------------
# Пути (шаги 50, 70, 90; make в приватном репо)
# ---------------------------------------------------------------------------
# Логическое окружение Ansible (ctl | stage | prod) задаётся в приватном репо: config/ansible-vars.yml (ключ env).

# Каталог клона приватного репозитория
PULL_DIR=/var/lib/infra/src

# 1 — не клонировать приватный репо и не вызывать make install-deps
SKIP_ANSIBLE=0
